---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Page Not Found | Custom Counseling LLC"
	description="That page doesn't exist, but you're not lost. Head back to the homepage or get in touch."
>
	<section class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
		<p class="font-display text-7xl font-semibold text-clay-400">404</p>
		<h1 class="mt-4 text-3xl md:text-4xl">This page doesn't exist</h1>
		<p class="mt-4 text-lg">
			No worries. You're not lost, and neither is the help you're looking for.
		</p>
		<div class="mt-8 flex flex-wrap justify-center gap-4">
			<a href="/" class="btn-primary">Back to home</a>
			<a href="/contact" class="btn-secondary">Contact me</a>
		</div>
	</section>
</Layout>
