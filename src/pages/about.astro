---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import CtaBand from '../components/CtaBand.astro';
import { getEntry, render } from 'astro:content';

const about = await getEntry('pages', 'about');
const { Content: Bio } = await render(about);

// The "fun" list survives the rebuild on purpose — it's the best trust
// content on the old site (build reference §4).
const funList = [
	'Making my rockstar wife laugh',
	'Playing with my Husky',
	'Going to the gym',
	'Watching any sports, but especially Manchester United, the Cincinnati Bengals, and the White Sox (it’s a long story)',
	'Cooking new recipes, especially smoking meat',
	'Watching The Office for the 100th time and going to live comedy shows',
	'Snowboarding with friends and family',
];
---

<Layout
	title="About Eric Tulga, [CRED] — Colorado Online Therapist"
	description="Meet Eric Tulga, [CRED] — a Colorado-licensed counselor working with adults and couples online. Warm, practical, and a little bit funny."
>
	<PageHero heading="Eric Tulga, [CRED]" subhead="A counselor you can actually talk to." />

	<section class="mx-auto grid max-w-6xl items-start gap-10 px-4 py-14 sm:px-6 md:grid-cols-5 md:py-20">
		<div class="md:col-span-2">
			<ImagePlaceholder label="Professional photo of Eric" ratio="4 / 5" />
			<!-- TODO (O1): credential + license number pending Eric's written confirmation. -->
			<div class="mt-6 rounded-lg border border-stone-200 bg-white p-6 text-sm shadow-sm">
				<h2 class="text-lg">Credentials</h2>
				<ul class="mt-3 space-y-2">
					<li>[CRED] — Licensed Professional Counselor, Colorado</li>
					<li>License #[PENDING]</li>
					<li>Years of practice in the Denver area, now fully online</li>
				</ul>
			</div>
		</div>
		<div class="md:col-span-3">
			<h2 class="text-3xl">Why I do this work</h2>
			<div class="prose-site mt-5 text-lg">
				<Bio />
			</div>

			<h2 class="mt-12 text-3xl">What I like to do for fun</h2>
			<ul class="prose-site mt-5 list-disc space-y-2 pl-6 text-lg">
				{funList.map((item) => <li>{item}</li>)}
			</ul>
		</div>
	</section>

	<CtaBand
		heading="Want to see if we're a good fit?"
		body="The first step is a free 15-minute phone call. No pressure, no commitment."
	/>
</Layout>
