---
import Layout from '../layouts/Layout.astro';
import ServiceCards from '../components/ServiceCards.astro';
import FirstSteps from '../components/FirstSteps.astro';
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
// Hero background: Maroon Bells, Colorado. Photo by GSN Travel via Pexels (free license).
import heroBg from '../assets/images/hero-maroon-bells.jpg';
import manPhoto from '../assets/images/man-online-session.jpg';

// Hero + intro copy is CMS-editable (pages/home); layout stays code-only.
const home = await getEntry('pages', 'home');
const { Content: HomeBody } = await render(home);
const settings = await getEntry('settings', 'site');

// JSON-LD per build-reference §6: LocalBusiness, areaServed Colorado, no street address.
const jsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	'@id': 'https://denvercustomcounseling.com/#practice',
	name: 'Custom Counseling LLC',
	url: 'https://denvercustomcounseling.com/',
	telephone: '+1-720-235-8357',
	email: settings.data.email,
	description:
		'Online counseling for adults and couples across Colorado: anxiety, depression, addiction, men’s counseling, couples counseling, and counseling for veterans.',
	founder: { '@type': 'Person', name: 'Eric Tulga' },
	areaServed: { '@type': 'State', name: 'Colorado' },
	priceRange: '$140-$175',
});
---

<Layout
	title="Online Therapy in Colorado | Custom Counseling LLC"
	description="Online counseling for adults and couples across Colorado. Anxiety, depression, addiction, and men's counseling with Eric Tulga, MA, LPC. Free 15-minute consultation."
>
	<script slot="head" type="application/ld+json" set:html={jsonLd} />

	<!-- Hero -->
	<section class="relative isolate overflow-hidden border-b border-stone-200">
		<!-- Full-bleed Colorado mountains background + dark scrim so the copy stays legible. -->
		<Image
			src={heroBg}
			alt=""
			widths={[768, 1280, 1920, 2560]}
			sizes="100vw"
			loading="eager"
			class="absolute inset-0 -z-10 h-full w-full object-cover object-center md:object-top"
		/>
		<div
			class="absolute inset-0 -z-10 bg-linear-to-b from-ink-950/20 via-ink-950/35 to-ink-950/50"
		>
		</div>

		<div
			class="mx-auto flex max-w-3xl flex-col items-center px-4 py-24 text-center text-cream-50 [text-shadow:0_1px_3px_rgb(0_0_0/0.45)] sm:px-6 md:py-32"
		>
			<h1 class="font-display text-3xl italic sm:text-4xl md:text-5xl">
				{home.data.heroSlogan}
			</h1>
			<p class="mt-5 text-lg md:text-xl">
				{home.data.heroTagline}
			</p>
			<div class="mt-8 flex justify-center">
				<a href="/contact" class="btn-primary">Free consultation</a>
			</div>
		</div>
	</section>

	<!-- Welcome (CMS-editable intro) -->
	<section class="mx-auto max-w-3xl px-4 py-14 sm:px-6 md:py-20">
		<h2 class="text-center text-3xl md:text-4xl">Welcome to Custom Counseling</h2>
		<div class="prose-site mt-8 text-lg">
			<HomeBody />
		</div>
	</section>

	<!-- Services teaser -->
	<section class="border-y border-stone-200 bg-white">
		<div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 md:py-20">
			<h2 class="text-center text-3xl md:text-4xl">How I can help</h2>
			<p class="mx-auto mt-4 max-w-2xl text-center text-lg">
				Every plan is custom. These are the areas I know best.
			</p>
			<div class="mt-10">
				<ServiceCards />
			</div>
			<p class="mt-8 text-center">
				<a href="/services" class="btn-secondary">See all services</a>
			</p>
		</div>
	</section>

	<!-- Online-first reassurance -->
	<section class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-14 sm:px-6 md:grid-cols-2 md:py-20">
		<div class="overflow-hidden rounded-lg shadow-sm" style="aspect-ratio: 4 / 5">
			<Image
				src={manPhoto}
				alt="A man on a video counseling session on his laptop by a sunny window at home"
				width={800}
				height={1200}
				densities={[1, 2]}
				class="h-full w-full object-cover object-[50%_30%]"
			/>
		</div>
		<div>
			<h2 class="text-3xl md:text-4xl">Counseling from wherever you are</h2>
			<div class="prose-site mt-5">
				<p>
					Online counseling can be just as effective as in-person. You can meet me wherever you
					are: home, your parked car on a lunch break, anywhere you can talk freely.
				</p>
				<p>
					Sessions happen over a secure Google Meet link. All you need is a phone or computer and
					a private spot.
				</p>
				<p><a href="/telehealth">See how online sessions work</a></p>
			</div>
		</div>
	</section>

	<FirstSteps />
</Layout>
