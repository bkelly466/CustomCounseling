---
// Gray placeholder box shown until Eric's professional photos arrive (D10).
// Swap each instance for an <img> or <Image> with real width/height + alt text.
interface Props {
	label: string;
	class?: string;
	/** CSS aspect-ratio value, e.g. "4 / 3" */
	ratio?: string;
}
const { label, class: className, ratio = '4 / 3' } = Astro.props;
---

<div
	role="img"
	aria-label={`Placeholder: ${label}`}
	class:list={[
		'flex items-center justify-center rounded-lg border-2 border-dashed border-stone-200 bg-stone-100',
		className,
	]}
	style={`aspect-ratio: ${ratio}`}
>
	<span class="px-6 text-center text-sm text-slate-500">
		<svg
			aria-hidden="true"
			class="mx-auto mb-2 h-8 w-8"
			fill="none"
			stroke="currentColor"
			stroke-width="1.5"
			viewBox="0 0 24 24"
		>
			<rect x="3" y="5" width="18" height="14" rx="2"></rect>
			<circle cx="9" cy="10" r="1.5"></circle>
			<path stroke-linecap="round" d="m5 17 4.5-4.5 3 3L16 12l3 3"></path>
		</svg>
		{label}
	</span>
</div>
