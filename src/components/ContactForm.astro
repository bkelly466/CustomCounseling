---
// Contact form per build-reference §7: name, email, phone (optional),
// free-text "what's bringing you here?" (optional). Nothing clinical.
//
// STUB: the Web3Forms access key below is a placeholder. Once the account is
// registered with Eric's email (ADR action item), replace ACCESS_KEY and the
// form goes live — no other changes needed. Until then a tiny script
// intercepts submit and shows the success panel so the prototype is demoable.
import { getEntry } from 'astro:content';

const settings = await getEntry('settings', 'site');
const ACCESS_KEY = 'WEB3FORMS_ACCESS_KEY_PLACEHOLDER';
---

<form
	id="contact-form"
	action="https://api.web3forms.com/submit"
	method="POST"
	class="space-y-5 rounded-lg border border-stone-200 bg-white p-6 shadow-sm sm:p-8"
>
	<input type="hidden" name="access_key" value={ACCESS_KEY} />
	<input type="hidden" name="subject" value="New inquiry from denvercustomcounseling.com" />
	<!-- Honeypot: hidden from people, catnip for bots. -->
	<input type="checkbox" name="botcheck" class="hidden" tabindex="-1" aria-hidden="true" />

	<div>
		<label for="name" class="mb-1 block text-sm font-semibold">Name</label>
		<input
			type="text"
			id="name"
			name="name"
			required
			autocomplete="name"
			class="w-full rounded border border-stone-200 bg-cream-50 px-3 py-2"
		/>
	</div>

	<div>
		<label for="email" class="mb-1 block text-sm font-semibold">Email</label>
		<input
			type="email"
			id="email"
			name="email"
			required
			autocomplete="email"
			class="w-full rounded border border-stone-200 bg-cream-50 px-3 py-2"
		/>
	</div>

	<div>
		<label for="phone" class="mb-1 block text-sm font-semibold">
			Phone <span class="font-normal text-slate-500">(optional)</span>
		</label>
		<input
			type="tel"
			id="phone"
			name="phone"
			autocomplete="tel"
			class="w-full rounded border border-stone-200 bg-cream-50 px-3 py-2"
		/>
	</div>

	<div>
		<label for="message" class="mb-1 block text-sm font-semibold">
			What's bringing you here? <span class="font-normal text-slate-500">(optional)</span>
		</label>
		<textarea
			id="message"
			name="message"
			rows="4"
			class="w-full rounded border border-stone-200 bg-cream-50 px-3 py-2"></textarea>
	</div>

	<!--
		No captcha here, deliberately. See ADR-002: the access key is public in
		the page source, so a spammer can POST straight to api.web3forms.com and
		skip the honeypot above. hCaptcha would close that, but we measured it
		and it sets third-party cookies and pulls in the deprecated Protected
		Audience ad-targeting API — on the contact page of a mental-health site,
		which is the worst possible place for it. Not worth it while the risk is
		still theoretical.

		If spam becomes real, the fix is the self-built Pages Function +
		Turnstile form (ADR-001 parked it as a post-launch project), not a
		captcha bolted onto the free tier.
	-->
	<button type="submit" class="btn-primary w-full sm:w-auto">Send message</button>

	<p class="text-sm text-slate-800">{settings.data.responsePromise}</p>

	<p class="border-t border-stone-200 pt-4 text-xs leading-relaxed text-slate-500">
		{settings.data.telehealthDisclaimer}
	</p>
</form>

<div
	id="form-success"
	hidden
	role="status"
	class="rounded-lg border border-stone-200 bg-stone-100 p-8 text-center"
>
	<h3 class="text-2xl">Thank you!</h3>
	<p class="mt-3">Your message is on its way. {settings.data.responsePromise}</p>
	<p class="mt-4 text-xs text-slate-500">
		(Prototype preview: the live form will be connected before launch.)
	</p>
</div>

<script>
	// Prototype-only: while the access key is a placeholder, fake the success
	// state instead of posting. Delete this block once the real key is in.
	const form = document.getElementById('contact-form') as HTMLFormElement | null;
	const success = document.getElementById('form-success');
	const key = form?.querySelector<HTMLInputElement>('input[name="access_key"]')?.value;
	if (form && key?.includes('PLACEHOLDER')) {
		form.addEventListener('submit', (event) => {
			event.preventDefault();
			if (!form.reportValidity()) return;
			form.hidden = true;
			if (success) success.hidden = false;
			success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
		});
	}
</script>
