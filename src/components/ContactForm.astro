---
// Contact form per build-reference §7: name, email, phone (optional),
// free-text "what's bringing you here?" (optional). Nothing clinical.
//
// Web3Forms access key. Public by design (it sits in the page source). Currently
// registered to Brandon's inbox for testing — SWITCH TO ERIC'S EMAIL AT LAUNCH
// (register a new key at web3forms.com with Eric's address, per RUNBOOK.md).
import { getEntry } from 'astro:content';

const settings = await getEntry('settings', 'site');
const ACCESS_KEY = '6c7cb2d4-8f39-469c-9229-f4dd3bc6087c';
---

<form
	id="contact-form"
	action="https://api.web3forms.com/submit"
	method="POST"
	class="space-y-5 rounded-lg border border-stone-200 bg-white p-6 shadow-sm sm:p-8"
>
	<input type="hidden" name="access_key" value={ACCESS_KEY} />
	<input type="hidden" name="subject" value="New inquiry from denvercustomcounseling.com" />
	<!-- Honeypot: hidden from people, catnip for bots. -->
	<input type="checkbox" name="botcheck" class="hidden" tabindex="-1" aria-hidden="true" />

	<div>
		<label for="name" class="mb-1 block text-sm font-semibold">Name</label>
		<input
			type="text"
			id="name"
			name="name"
			required
			autocomplete="name"
			class="w-full rounded border border-stone-200 bg-cream-50 px-3 py-2"
		/>
	</div>

	<div>
		<label for="email" class="mb-1 block text-sm font-semibold">Email</label>
		<input
			type="email"
			id="email"
			name="email"
			required
			autocomplete="email"
			class="w-full rounded border border-stone-200 bg-cream-50 px-3 py-2"
		/>
	</div>

	<div>
		<label for="phone" class="mb-1 block text-sm font-semibold">
			Phone <span class="font-normal text-slate-500">(optional)</span>
		</label>
		<input
			type="tel"
			id="phone"
			name="phone"
			autocomplete="tel"
			class="w-full rounded border border-stone-200 bg-cream-50 px-3 py-2"
		/>
	</div>

	<div>
		<label for="message" class="mb-1 block text-sm font-semibold">
			What's bringing you here? <span class="font-normal text-slate-500">(optional)</span>
		</label>
		<textarea
			id="message"
			name="message"
			rows="4"
			class="w-full rounded border border-stone-200 bg-cream-50 px-3 py-2"></textarea>
	</div>

	<!--
		No captcha here, deliberately. See ADR-002: the access key is public in
		the page source, so a spammer can POST straight to api.web3forms.com and
		skip the honeypot above. hCaptcha would close that, but we measured it
		and it sets third-party cookies and pulls in the deprecated Protected
		Audience ad-targeting API — on the contact page of a mental-health site,
		which is the worst possible place for it. Not worth it while the risk is
		still theoretical.

		If spam becomes real, the fix is the self-built Pages Function +
		Turnstile form (ADR-001 parked it as a post-launch project), not a
		captcha bolted onto the free tier.
	-->
	<button type="submit" class="btn-primary w-full sm:w-auto">Send message</button>

	<p id="form-error" hidden role="alert" class="text-sm font-medium text-red-700"></p>

	<p class="text-sm text-slate-800">{settings.data.responsePromise}</p>

	<p class="border-t border-stone-200 pt-4 text-xs leading-relaxed text-slate-500">
		{settings.data.telehealthDisclaimer}
	</p>
</form>

<div
	id="form-success"
	hidden
	role="status"
	class="rounded-lg border border-stone-200 bg-stone-100 p-8 text-center"
>
	<h3 class="text-2xl">Thank you!</h3>
	<p class="mt-3">Your message is on its way. {settings.data.responsePromise}</p>
</div>

<script>
	// Submits to Web3Forms via its JSON API so visitors stay on the page and see
	// the success panel in place, with a loading state and an inline error on failure.
	const form = document.getElementById('contact-form') as HTMLFormElement | null;
	const success = document.getElementById('form-success');
	const error = document.getElementById('form-error');

	function showSuccess() {
		if (!form) return;
		form.hidden = true;
		if (success) success.hidden = false;
		success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
	}

	function showError(message?: string) {
		if (!error) return;
		error.textContent =
			message ||
			'Something went wrong sending your message. Please try again, or call/text us instead.';
		error.hidden = false;
	}

	if (form) {
		const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			if (!form.reportValidity()) return;
			if (error) error.hidden = true;

			const label = button?.textContent ?? 'Send message';
			if (button) {
				button.disabled = true;
				button.textContent = 'Sending…';
			}

			try {
				const response = await fetch('https://api.web3forms.com/submit', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(Object.fromEntries(new FormData(form))),
				});
				const data = await response.json();
				if (data.success) {
					showSuccess();
				} else {
					showError(data.message);
				}
			} catch {
				showError();
			} finally {
				if (button) {
					button.disabled = false;
					button.textContent = label;
				}
			}
		});
	}
</script>
