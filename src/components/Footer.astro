---
import { getCollection, getEntry } from 'astro:content';

const settings = await getEntry('settings', 'site');
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const year = new Date().getFullYear();
---

<footer class="bg-slate-800 text-stone-100">
	<div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-3">
		<div class="space-y-3">
			<p class="font-display text-xl font-semibold text-white">Custom Counseling LLC</p>
			<p class="text-sm italic">Empowering you to make enduring change.</p>
			<p class="text-sm">{settings.data.serviceArea}</p>
			<!-- TODO (O1): replace [CRED] + license number once Eric confirms in writing. -->
			<p class="text-sm">Eric Tulga, [CRED] · Licensed in Colorado · License #[PENDING]</p>
		</div>

		<nav aria-label="Services" class="space-y-3">
			<p class="text-sm font-semibold tracking-wide text-clay-400 uppercase">Services</p>
			<ul class="space-y-2 text-sm">
				{
					services.map((service) => (
						<li>
							<a href={service.data.href ?? '/services'} class="hover:text-clay-400 hover:underline">
								{service.data.title}
							</a>
						</li>
					))
				}
				<li>
					<a href="/services" class="hover:text-clay-400 hover:underline">All services</a>
				</li>
			</ul>
		</nav>

		<div class="space-y-3">
			<p class="text-sm font-semibold tracking-wide text-clay-400 uppercase">Get in touch</p>
			<ul class="space-y-2 text-sm">
				<li>
					<a href="/contact" class="font-semibold text-white hover:text-clay-400 hover:underline"
						>Send me a message</a
					>
				</li>
				<li>
					Call or text{' '}
					<a href={`tel:${settings.data.phone}`} class="hover:text-clay-400 hover:underline"
						>{settings.data.phone}</a
					>
				</li>
				<li>
					<a href={`mailto:${settings.data.email}`} class="hover:text-clay-400 hover:underline"
						>{settings.data.email}</a
					>
				</li>
				<li><a href="/telehealth" class="hover:text-clay-400 hover:underline">How online sessions work</a></li>
				<li><a href="/privacy" class="hover:text-clay-400 hover:underline">Privacy &amp; disclosures</a></li>
			</ul>
			<p class="border-t border-slate-500/50 pt-3 text-xs leading-relaxed">
				If you are in crisis, call or text <a
					href="tel:988"
					class="font-semibold text-white underline">988</a
				> (Suicide &amp; Crisis Lifeline) or 911. This website is not monitored for emergencies.
			</p>
		</div>
	</div>
	<div class="border-t border-slate-500/50">
		<p class="mx-auto max-w-6xl px-4 py-4 text-xs sm:px-6">
			&copy; {year} Custom Counseling LLC. All rights reserved.
		</p>
	</div>
</footer>
