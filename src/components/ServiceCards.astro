---
// Grid of service cards driven by the CMS-editable services collection.
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
	{
		services.map((service) => (
			<li class="group relative flex flex-col rounded-lg border border-stone-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
				<h3 class="text-xl">
					<a
						href={service.data.href ?? '/services'}
						class="after:absolute after:inset-0 group-hover:text-clay-700"
					>
						{service.data.title}
					</a>
				</h3>
				<p class="mt-3 flex-1 text-sm leading-relaxed text-slate-800">{service.data.summary}</p>
				<span
					aria-hidden="true"
					class="mt-4 text-sm font-semibold text-clay-700 group-hover:underline"
				>
					Learn more &rarr;
				</span>
			</li>
		))
	}
</ul>
