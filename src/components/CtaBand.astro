---
// Mid-page call to action. Form leads (D5); call/text is present but secondary.
import { getEntry } from 'astro:content';

interface Props {
	heading?: string;
	body?: string;
}
const { heading = "Let's start today", body = 'Reach out and tell me a little about what brings you here. I can help.' } =
	Astro.props;
const settings = await getEntry('settings', 'site');
---

<section class="bg-stone-100">
	<div class="mx-auto max-w-3xl px-4 py-12 text-center sm:px-6 md:py-16">
		<h2 class="text-2xl md:text-3xl">{heading}</h2>
		<p class="mt-3 text-lg">{body}</p>
		<div class="mt-6 flex flex-wrap items-center justify-center gap-4">
			<a href="/contact" class="btn-primary">Get in touch</a>
			<a href={`tel:${settings.data.phone}`} class="text-sm font-medium text-slate-800 underline underline-offset-2 hover:text-clay-700">
				or call/text {settings.data.phone}
			</a>
		</div>
	</div>
</section>
